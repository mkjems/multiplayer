{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "rootDir": ".",
    "outDir": "../public",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "strict": true,
    "noEmitOnError": true,
    "sourceMap": false,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "rewriteRelativeImportExtensions": true
  },
  "references": [{ "path": "../shared" }],
  "include": ["./**/*.ts"]
}
