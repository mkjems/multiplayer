{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "rootDir": "..",
    "outDir": "../public",
    "tsBuildInfoFile": "../../dist/client.tsbuildinfo",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "jsx": "react-jsx",
    "composite": true,
    "strict": true,
    "noEmitOnError": true,
    "sourceMap": false,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": ["./**/*.ts", "./**/*.tsx", "../shared/**/*.ts"],
  "exclude": ["./**/*_test.ts", "../shared/**/*_test.ts"]
}
